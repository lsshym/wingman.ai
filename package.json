{
  "name": "wingman",
  "version": "1.0.0",
  "private": false,
  "description": "Cross-platform AI engineering plugin for execution, context, and reuse.",
  "files": [
    ".agents/",
    ".claude-plugin/",
    ".codex-plugin/",
    ".cursor-plugin/",
    "assets/",
    "docs/",
    "hooks/",
    "skills/",
    "README.md",
    "LICENSE",
    "PRIVACY.md",
    "TERMS.md"
  ],
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:plugin && npm run test:package && npm run test:behavior && npm run check:plugin",
    "test:plugin": "node --test tests/plugin/*.test.mjs",
    "test:package": "node --test tests/package/*.test.mjs",
    "test:behavior": "node --test tests/behavior/*.test.mjs",
    "check:plugin": "node scripts/check-plugin.mjs",
    "sync:codex": "bash scripts/sync-to-codex-plugin.sh",
    "prepare:codex-local": "bash scripts/sync-to-codex-plugin.sh --dest ."
  },
  "author": "keni",
  "homepage": "https://github.com/lsshym/wingman.ai",
